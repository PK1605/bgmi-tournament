# Firebase (from Firebase Console > Project Settings > Service Accounts > Generate Private Key)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Razorpay (use rzp_test_MOCK for local testing, live keys for production)
RAZORPAY_KEY_ID=rzp_test_MOCK
RAZORPAY_KEY_SECRET=mock_secret_key

# Admin auth (generate with: openssl rand -hex 32)
ADMIN_SECRET=dev_secret_change_me

# Setup secret (one-time use to seed database, then delete)
SETUP_SECRET=setup_change_me_too
