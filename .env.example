# ====================================
# Copy this file to .env and fill values
# cp .env.example .env
# ====================================

# Firebase (from Firebase Console > Project Settings > Service Accounts > Generate Private Key)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Razorpay (test keys from Razorpay Dashboard > Settings > API Keys)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Admin auth secret (generate with: openssl rand -hex 32)
ADMIN_SECRET=

# Setup secret (one-time use to seed database)
SETUP_SECRET=

# WhatsApp Business API (from Meta Business Manager > WhatsApp > API Setup)
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=

# Cron secret (for scheduled room broadcast)
CRON_SECRET=
